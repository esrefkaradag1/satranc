# ── Self-hosted Supabase ─────────────────────────────────────────────────────
# REST/API URL (Kong gateway — genelde https://db.ALANADINIZ.com veya api.*)
SUPABASE_HOST=db.example.com
POSTGRES_PASSWORD=
JWT_SECRET=

VITE_SUPABASE_URL=https://db.example.com
VITE_SUPABASE_ANON_KEY=

# Admin panel yazma + veli imza API (prod)
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Sunucu API (Docker / Vercel — VITE_ olmadan)
SUPABASE_URL=https://db.example.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── Canlı ders video (Agora) ─────────────────────────────────────────────────
VITE_AGORA_APP_ID=
VITE_AGORA_CHANNEL_PREFIX=satranc

# ── AI (opsiyonel) ───────────────────────────────────────────────────────────
VITE_OPENROUTER_API_KEY=

# ── Lichess OAuth ─────────────────────────────────────────────────────────────
VITE_LICHESS_OAUTH_CLIENT_ID=netchess-academy
LICHESS_OAUTH_CLIENT_ID=netchess-academy

