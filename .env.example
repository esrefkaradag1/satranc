# ── Supabase (zorunlu) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin panel yazma + veli imza API (zorunlu — prod)
# Tarayıcıda da kullanılır (canWriteSupabase); güvenlik için yalnızca güvenilir ortamda.
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Vercel serverless API (/api/submit-parent-signature, load-parent-consent)
# Aynı değer; VITE_ öneki olmadan da tanımlayın:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Canlı ders video (Agora) ─────────────────────────────────────────────────
VITE_AGORA_APP_ID=
VITE_AGORA_CHANNEL_PREFIX=satranc

# ── AI (opsiyonel) ───────────────────────────────────────────────────────────
VITE_OPENROUTER_API_KEY=

# ── Lichess OAuth (öğrenci bulmaca geçmişi) ─────────────────────────────────
# Lichess hesabınızda OAuth uygulaması oluşturun: https://lichess.org/account/oauth/app
# Redirect URI: https://SIZIN-DOMAIN/lichess-oauth-callback.html
# İzin: puzzle:read
VITE_LICHESS_OAUTH_CLIENT_ID=netchess-academy
# VITE_LICHESS_OAUTH_REDIRECT_URI=https://example.com/lichess-oauth-callback.html
LICHESS_OAUTH_CLIENT_ID=netchess-academy

# ── Öğrenci API (opsiyonel — farklı cihaz senkronu) ─────────────────────────
# VITE_API_URL=https://api.ornek.com
